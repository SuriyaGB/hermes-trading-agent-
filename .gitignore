# =========================
# SECRETS & KEYS (NEVER PUSH)
# =========================
.env
.hermes/.env
*.key
frontend/.env.local

# =========================
# ENVIRONMENTS & DEPENDENCIES
# =========================
.venv/
frontend/node_modules/
cloudflared-linux-amd64.deb

# =========================
# TEMPORARY PYTHON FILES
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# SQLITE TEMPORARY FILES
# =========================
*.db-shm
*.db-wal
hermes_cache.sqlite

# =========================
# RUNTIME LOGS
# =========================
logs/
*.log

# =========================
# LIVE RUNTIME DATA
# =========================
data/
*.db
*.json

# =========================
# PM2 / CACHE / TEMP
# =========================
.cache/
tmp/
temp/
*.pid
